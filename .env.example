# ---------------------------------------------------------------------------
# Rufuspa — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Convex ---------------------------------------------------------------
# Set automatically by `npx convex dev`. This is the public deployment URL.
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (authentication) ----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# The Clerk JWT issuer domain, used by Convex to verify identity tokens.
# Found in Clerk Dashboard > JWT Templates > "convex" template (Issuer URL).
# e.g. https://your-app.clerk.accounts.dev
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=
# Optional: sign-in/up routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Optional: verify Clerk webhooks (user sync). From Clerk Dashboard > Webhooks.
CLERK_WEBHOOK_SECRET=

# --- OpenAI (assistant, speech-to-text, optional TTS) ---------------------
# Set this in the Convex deployment environment too: `npx convex env set OPENAI_API_KEY sk-...`
OPENAI_API_KEY=
# Model overrides (optional)
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Text-to-speech (assistant speaks replies aloud)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# --- Google Calendar (OAuth) ---------------------------------------------
# Create an OAuth 2.0 Client (Web application) in Google Cloud Console.
# Scope: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console, e.g.
# http://localhost:3000/api/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# --- Automation providers (optional, future connectors) -------------------
# The MVP ships a ManualMonitorProvider. These are placeholders for later.
BROWSERBASE_API_KEY=
BROWSERLESS_TOKEN=

# --- App ------------------------------------------------------------------
# Public base URL, used to build OAuth redirect URIs in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# TODO (production hardening):
#  - Encrypt OAuth tokens at rest (see convex/integrations/tokenStore.ts TODOs).
#  - Add a KMS-managed encryption key here, e.g. TOKEN_ENCRYPTION_KEY.
#  - Add rate-limiting secrets / provider keys as needed.
# ---------------------------------------------------------------------------
